{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "<SecurityKey>", //HelpdeskServiceSuperSecretKey_ChangeInProduction_32chars!
    "Issuer": "<Issuer>", //HelpdeskService
    "Audience": "HelpdeskServiceUsers",
    "ExpirationInMinutes": 60
  },
  "ConnectionString": {
    "DefaultConnection": "Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<db>;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:4200" // angular frontend
    ]
  }
}
